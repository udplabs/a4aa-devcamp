{
  "name": "devcamp-ai-chat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/find-port.js && concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "test:provision": "node scripts/test-provision.js",
    "test:hooks": "node scripts/test-hooks.js"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.2.4",
    "@openfga/sdk": "^0.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "marked": "^14.1.2",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^5.4.3"
  }
}
