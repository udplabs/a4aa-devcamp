# Port the service listens on
PORT=3000

# Public base URL of this service (used in JWT iss/aud claims and AS metadata).
# Must match the URL Auth0 will call for /authorize and /token.
BASE_URL=https://your-mock-crm.example.com

# Secret used to sign and verify JWTs issued by this service.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# OAuth2 client credentials. Auth0 presents these when exchanging codes at /token.
# Set the same values in Auth0 when creating the custom social connection.
OAUTH_CLIENT_ID=retailzero-crm
OAUTH_CLIENT_SECRET=
