# Port the service listens on (local dev only; Vercel ignores this)
PORT=3000

# Public base URL of this service. Must match the URL Auth0 will call
# for /authorize and /token when registering the custom social connection.
# On Vercel: https://your-project.vercel.app
BASE_URL=https://your-mock-crm.vercel.app

# Secret used to sign and verify both auth codes and access tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# OAuth2 client credentials. Auth0 presents these when exchanging codes
# at /token. Set the same values in the Auth0 custom social connection.
OAUTH_CLIENT_ID=nexus-crm
OAUTH_CLIENT_SECRET=
