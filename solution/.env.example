# ===========================================
# Auth0 Configuration - DevCamp AI Chat Lab
# ===========================================

# Frontend (Vite - must be prefixed with VITE_)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://devcamp-ai-api

# Backend (Express)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://devcamp-ai-api

# CIBA (Lab 2)
AUTH0_CIBA_CLIENT_ID=your-ciba-client-id
AUTH0_CIBA_CLIENT_SECRET=your-ciba-client-secret

# MCP Server (Lab 5)
MCP_SERVER_PORT=3001
MCP_AUTH0_AUDIENCE=https://devcamp-mcp-server
AUTH0_CLIENT_ID_M2M=your-m2m-client-id
AUTH0_CLIENT_SECRET_M2M=your-m2m-client-secret

# Token Vault / Third-Party API (Lab 4)
THIRD_PARTY_API_PORT=3002

# OpenAI (optional -- enables real AI responses with tool calling)
# Without this key, the app falls back to a pattern-matching simulator.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
