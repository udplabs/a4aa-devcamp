# =============================================================
# RetailZero Z-Merchant — starter-test/ environment
# Copy this file to .env.local and fill in values.
# =============================================================

# -------------------------------------------------------------
# Frontend (Vite) — must be prefixed with VITE_
# -------------------------------------------------------------
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://devcamp-retailzero-api

# -------------------------------------------------------------
# Backend (Express API on :3000)
# -------------------------------------------------------------
PORT=3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://devcamp-retailzero-api

# -------------------------------------------------------------
# MCP Server (Lab 05)
# -------------------------------------------------------------
MCP_SERVER_PORT=3001
MCP_AUTH0_AUDIENCE=https://devcamp-mcp-server
AUTH0_CLIENT_ID_M2M=your-m2m-client-id
AUTH0_CLIENT_SECRET_M2M=your-m2m-client-secret

# -------------------------------------------------------------
# LLM (optional) — enables real AI responses with tool calling.
# Without a key, the app falls back to a pattern-matching simulator.
#
# Option 1 — OpenAI directly
#   OPENAI_API_KEY=sk-...
#   (leave OPENAI_BASE_URL and LLM_MODEL unset; defaults to gpt-4o-mini)
#
# Option 2 — LiteLLM proxy (or any OpenAI-compatible endpoint)
#   OPENAI_API_KEY=<your litellm virtual key>
#   OPENAI_BASE_URL=https://your-litellm-proxy.example.com/v1
#   LLM_MODEL=claude-opus-4-6    # whatever model your proxy exposes
# -------------------------------------------------------------
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
# LLM_MODEL=
